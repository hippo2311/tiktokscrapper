{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "includeFiles": "templates/**,static/**,src/**",
      "excludeFiles": "{**/__pycache__/**,output/**,tests/**,.pytest_cache/**}"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
